programa {
  funcao inicio() {
    //8.	Converta uma variável double para int e exiba o valor antes e depois da conversão.
    real numeroReal
    inteiro numeroInteiro

    escreva("Digite um número: ")
    leia(numeroReal)
    numeroInteiro = numeroReal

        escreva("Valor real: ", numeroReal, "\n")
        escreva("Valor inteiro (truncado): ", numeroInteiro, "\n")
  }
}
