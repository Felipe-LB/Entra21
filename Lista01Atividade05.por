programa {
  funcao inicio() {
    //5.	Verifique se um número inteiro lido do teclado é par ou ímpar.
    inteiro numero
    escreva("Digite um número inteiro: ")
    leia(numero)
    se (numero % 2 == 0){
      escreva("o número é par!")
    } 
    senao{
      escreva("o número é ímpar!")
    }
  }
}
