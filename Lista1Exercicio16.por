programa {
  funcao inicio() {
    //16.	Crie um programa que leia um número decimal e converta para inteiro.
    real numeroDecimal
    inteiro numeroInteiro

    escreva("Digite um número real(decimal): ")
    leia(numeroDecimal)

    numeroInteiro = numeroDecimal 

    escreva("Esse número convertido para inteiro é: " + numeroInteiro)

  }
}
